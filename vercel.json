{
  "name": "bizmtaani-frontend",
  "framework": null,
  "buildCommand": "pnpm --filter @bizmtaani/frontend run build",
  "outputDirectory": "frontend/dist/public",
  "installCommand": "pnpm install --no-frozen-lockfile",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}